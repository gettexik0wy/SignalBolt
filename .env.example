# SignalBolt Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# EXCHANGE API KEYS
# =============================================================================

# Binance API (get from: https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

# For paper trading, you can use read-only keys
# For live trading, enable spot trading (but DISABLE withdrawal!)


# =============================================================================
# TELEGRAM BOT (Optional)
# =============================================================================

# Create bot: https://t.me/botfather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# To get chat_id:
# 1. Send message to your bot
# 2. Visit: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# 3. Look for "chat":{"id":123456789}


# =============================================================================
# DISCORD WEBHOOK (Optional)
# =============================================================================

DISCORD_WEBHOOK_URL=


# =============================================================================
# DASHBOARD (Optional)
# =============================================================================

FLASK_SECRET_KEY=your_random_secret_key_here
FLASK_DEBUG=False


# =============================================================================
# DATABASE (Optional - defaults to SQLite)
# =============================================================================

DATABASE_URL=sqlite:///data/signalbolt.db


# =============================================================================
# REDIS (Optional - for Celery task queue)
# =============================================================================

REDIS_URL=redis://localhost:6379/0


# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR


# =============================================================================
# TRADING MODE (for testing)
# =============================================================================

# Set to 'paper' to force paper trading mode
# SIGNALBOLT_MODE=paper